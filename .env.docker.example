# Copy this file to .env before running Docker if you want to change ports,
# database credentials, dashboard users, or automation tuning.

# Host ports. Change these if a port is already used on your machine.
WEB_PORT=5173
API_PORT=4100
BROWSER_DESKTOP_PORT=6080
POSTGRES_HOST_PORT=54322

# PostgreSQL container credentials.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Local npm run dev can use the Docker database through this URL.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Optional Docker API database override. Leave blank for the built-in db service.
APP_DATABASE_URL=
APP_SUPABASE_DATABASE_URL=

# Dashboard login users. Leave usernames as-is unless you want custom logins.
OPERATIONS_MANAGER_USERNAME=operations.manager
OPERATIONS_MANAGER_PASSWORD=Tinitiate@2026

POST_UPLOADER_USERNAME=content.uploader
POST_UPLOADER_PASSWORD=Uploader@2026

SCHEDULER_USERNAME=post.scheduler
SCHEDULER_PASSWORD=Scheduler@2026

VIEWER_USERNAME=workspace.viewer
VIEWER_PASSWORD=Viewer@2026

# Change both secrets before any real production use.
LOCAL_ACCOUNT_SECRET_KEY=replace-with-a-long-random-secret
AUTH_TOKEN_SECRET=replace-with-another-long-random-secret

# Scheduler and automation settings.
SCHEDULER_CRON=* * * * *
SCHEDULER_TIMEZONE=Asia/Kolkata
AUTOMATION_SLOW_MO_MS=120
AUTOMATION_FAILURE_HOLD_MS=30000

# Keep this as auto so Docker opens the noVNC browser desktop on the same host.
VITE_BROWSER_DESKTOP_URL=auto
